{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": [
        "agents/**/*",
        "skills/**/*",
        "config/**/*",
        "types/**/*",
        "utils/**/*",
        "cli/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}